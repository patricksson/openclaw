# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real keys.

# -- Postiz (social media posting) --
POSTIZ_API_KEY=

# -- Gemini (image generation for TikTok) --
GEMINI_API_KEY=

# -- DodoPayments --
DODO_API_KEY=
DODO_WEBHOOK_SECRET=

# -- Brevo (transactional email) --
BREVO_API_KEY=

# -- n8n (workflow automation) --
N8N_API_URL=
N8N_API_KEY=

# -- JWT signing for saas-api --
JWT_SECRET=

# -- Deployment --
APP_URL=https://automatyn.co
SAAS_API_PORT=3001
